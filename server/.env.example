DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ice_shop"
PORT=4000
API_URL="http://localhost:4000/api/v1"
LOG_LEVEL="info"
NODE_ENV="development"
# Секрет подписи access-токенов (HS256), минимум 32 символа.
JWT_ACCESS_SECRET="change-me-to-a-random-string-of-32-plus-chars"
# Origin фронтенда для CORS с credentials.
CORS_ORIGIN="http://localhost:5173"
# Обязательный пароль seed-админа (admin@example.test).
SEED_ADMIN_PASSWORD=""
# Monobank personal API (https://api.monobank.ua/, токен из кабинета).
# Пусто — оплата CARD создаёт заказ, но верификация выключена.
MONOBANK_TOKEN=""
# Счёт для выписки; "0" — дефолтный счёт UAH.
MONOBANK_ACCOUNT="0"
# Публичный URL webhook-а (https://<host>/api/v1/payments/webhook); пусто — регистрация пропускается.
MONOBANK_WEBHOOK_URL=""
# Send-ссылка карты/банки (https://send.monobank.ua/XXXX) — в ответ CARD-заказа
# уходит paymentUrl с предзаполненными суммой и комментарием.
MONOBANK_SEND_URL=""
# Реквизиты для перевода (номер карты/IBAN), ручной fallback при CARD-заказе.
MONOBANK_PAYMENT_DETAILS=""
