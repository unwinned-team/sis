generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  imageUrl String?
  products Product[]
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String
  price       Decimal          @db.Decimal(10, 2)
  categoryId  String
  imageUrl    String
  isAvailable Boolean          @default(true)
  isArchived  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  variants    ProductVariant[]
  cartItems   CartItem[]

  @@index([categoryId])
  @@index([categoryId, isArchived])
}

model ProductVariant {
  id        String     @id @default(cuid())
  productId String
  taste     String?
  size      String?
  price     Decimal    @db.Decimal(10, 2)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@index([productId])
}

model CartItem {
  id         String          @id @default(cuid())
  customerId String
  productId  String
  variantId  String?
  // Всегда = variantId ?? "": Postgres считает NULL-ы в unique-индексе
  // различными, поэтому дедупликация строк без варианта идёт через этот ключ.
  // Инвариант поддерживается кодом роутов корзины — только они пишут в таблицу.
  variantKey String          @default("")
  quantity   Int
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId, variantKey])
  @@index([customerId])
  @@index([productId])
  @@index([variantId])
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  email         String?        @unique
  phone         String?        @unique
  bonusBalance  Decimal        @default(0) @db.Decimal(10, 2)
  passwordHash  String? // null = аккаунт без пароля (walk-in/seed), логин невозможен
  role          Role           @default(CUSTOMER)
  isActive      Boolean        @default(true)
  totpSecret    String? // резерв под 2FA, на этом этапе не используется
  createdAt     DateTime       @default(now())
  orders        Order[]
  refreshTokens RefreshToken[]
  cartItems     CartItem[]
}

model RefreshToken {
  id           String      @id @default(cuid())
  tokenHash    String      @unique // sha256 сырого токена; сырой не храним
  customerId   String
  familyId     String // семья ротации = одна сессия/устройство
  client       TokenClient
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime    @default(now())
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([familyId])
  @@index([expiresAt])
}

model Order {
  id            String        @id @default(cuid())
  customerId    String
  totalAmount   Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        OrderStatus   @default(NEW)
  // Оплата CARD через личный счёт monobank: клиент указывает paymentRef в
  // комментарии перевода, воркер подтверждает по выписке. BONUS — сразу PAID.
  paymentStatus  PaymentStatus @default(PENDING)
  paymentRef     String?       @unique // короткий код для комментария перевода
  // Сумма к оплате = totalAmount + «копеечный хвост»; уникальна среди активных
  // заказов — по ней матчится перевод без комментария (карта другого банка).
  paymentAmount Decimal? @db.Decimal(10, 2)
  // = paymentAmount.toFixed(2), пока заказ PENDING/CLAIMED; null после PAID.
  // Postgres не сравнивает NULL-ы в unique — уникальность держится только для
  // активных заказов без partial-индекса, который Prisma в схеме не умеет.
  paymentAmountKey String? @unique
  verifyAttempts Int           @default(0)
  nextCheckAt    DateTime? // очередь воркера; null = не проверяется
  // Доставка Новой Почтой; null у старых заказов, созданных до этих полей.
  deliveryCity   String?
  deliveryRegion String?
  deliveryBranch String? // номер отделения; строка — бывают "1234а" и пункты
  createdAt     DateTime      @default(now())
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items         OrderItem[]

  @@index([customerId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, nextCheckAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId])
  @@index([productId])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum TokenClient {
  WEB
  MOBILE
}

enum PaymentMethod {
  CARD
  CASH
  BONUS
}

enum PaymentStatus {
  PENDING
  CLAIMED // webhook заявил оплату, ждёт подтверждения по выписке
  PAID
  FAILED // только вручную; воркер после лимита попыток оставляет CLAIMED
}

enum OrderStatus {
  NEW
  PROCESSING
  COMPLETED
  CANCELLED
}
